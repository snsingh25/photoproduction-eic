# Build output
bin/
*.o
*.d

# Only the bulky generated event/jet trees are ignored — PDFs, logs,
# and summary .txt inside data/ and data-jets/ are tracked so plots
# and run records live with the repo.
data/**/*.root
data-jets/**/*.root

# Images we don't want tracked (jpg/png screenshots, etc.);
# PDFs are intentionally NOT in this list.
*.jpg
*.jpeg
*.png
*.eps

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Backups / swap
*.backup
*.bak
*~
*.swp

# macOS / editors
.DS_Store
.vscode/
.idea/

# Python
__pycache__/
*.pyc
.venv/
venv/

# Local overrides to build.mk (paths differ per machine)
build.mk.local
